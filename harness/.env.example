# Copy to .env and fill in. The harness does NOT auto-load this file:
#   export $(grep -v '^#' .env | xargs)

# Required: OpenRouter API key. The model is selected per-session via the
# X-Harness-Model header, whose value must contain a "/" provider prefix
# (e.g. "google/gemma-4-26b-a4b-it"). Only OpenRouter is supported.
OPENROUTER_API_KEY=

# Optional (defaults shown)
HARNESS_PORT=8080
HARNESS_PROMPT_VARIANT=gis_detailed        # basic | gis_detailed
OPENROUTER_MAX_ITERATIONS=50               # tool-call round cap
HARNESS_MAX_CONCURRENT_SESSIONS=4          # parallelism limit
